// WebGPU compute shader for adaptive plasma background
@compute @workgroup_size(8, 8)
fn plasma_main(@builtin(global_invocation_id) id: vec3<u32>) {
    let uv = vec2<f32>(id.xy) / vec2<f32>(texture_size);
    let time = f32(frame) * 0.016;
    
    // Base plasma
    var value = sin(uv.x * 10.0 + time) + sin(uv.y * 10.0 + time);
    value += sin((uv.x + uv.y) * 5.0 + time * 2.0) * 0.5;
    
    // Modulate by system state
    let activity = system_state.execution_load; // 0.0 to 1.0
    let chaos = system_state.guard_conflict_count;
    
    // High activity = lightning filaments
    if (activity > 0.7) {
        value += noise(uv * 20.0 + time * 5.0) * activity;
    }
    
    // Guard conflicts = red turbulence
    let color = mix(
        vec3(0.0, 1.0, 0.53), // Circuit green (calm)
        vec3(1.0, 0.3, 0.18), // Guardian forge (conflict)
        chaos * 0.3
    );
    
    textureStore(output_texture, id.xy, vec4<f32>(color * (value * 0.5 + 0.5), 1.0));
}
```


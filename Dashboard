// WebGPU fragment shader snippet for liquid node surface
fn fragment_main(input: FragmentInput) -> FragmentOutput {
    let uv = input.uv;
    let noise = perlin_noise(uv * 4.0 + time * 0.5);
    let refraction = refract(view_dir, normal, 1.0 / 1.52); // Glass IOR
    let background = sample_background(uv + refraction.xy * noise * 0.1);
    let glow = pow(1.0 - length(uv - 0.5), 3.0) * node_color;
    return FragmentOutput(background * 0.7 + glow * 0.3);
}
```


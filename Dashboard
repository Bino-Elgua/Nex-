// Nodes as glowing orbs with depth
nodes.forEach((node, i) => {
  const geometry = new THREE.IcosahedronGeometry(node.size, 2);
  const material = new THREE.ShaderMaterial({
    vertexShader: nodeVertexShader,
    fragmentShader: nodeFragmentShader,
    uniforms: {
      time: { value: 0 },
      color: { value: new THREE.Color(node.color) },
      depth: { value: node.executionDepth * 0.5 } // Z-depth based on recency
    },
    transparent: true
  });
  
  const mesh = new THREE.Mesh(geometry, material);
  mesh.position.set(node.x, node.y, node.executionDepth * 0.5);
  orrery.add(mesh);
});

// Gyroscope-controlled camera orbit
window.addEventListener('deviceorientation', (e) => {
  camera.position.x = Math.sin(e.gamma * Math.PI / 180) * 10;
  camera.position.z = Math.cos(e.gamma * Math.PI / 180) * 10;
  camera.lookAt(0, 0, 0);
});
